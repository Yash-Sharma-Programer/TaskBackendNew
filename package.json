{
  "name": "taskflow-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed/seed.js",
    "email:verify": "node src/utils/verify-email.js",
    "test": "MONGOMS_DOWNLOAD_DIR=../node_modules/.cache/mongodb-memory-server NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit",
    "test:watch": "MONGOMS_DOWNLOAD_DIR=../node_modules/.cache/mongodb-memory-server NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.10.1",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.0.0"
  },
  "jest": { "testEnvironment": "node", "transform": {}, "testMatch": ["**/tests/**/*.test.js"] }
}
